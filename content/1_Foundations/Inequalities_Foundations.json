      "tags": [
        "Extremal Principle",
        "Maximization"
      ],
      "statement": "The distance between the $5^{\\text{th}}$ and $26^{\\text{th}}$ exits on an interstate highway is $118$ miles. If any two exits are at least $5$ miles apart, then what is the largest number of miles there can be between two consecutive exits that are between the $5^{\\text{th}}$ and $26^{\\text{th}}$ exits?",
      "interaction": {
        "type": "mcq",
        "choices": [
          "$8$",
          "$13$",
          "$18$",
          "$47$",
          "$98$"
