<!-- copied from contact page index, with edits -->
<script id="footer-tpl-email-dialog" type="text/x-handlebars-template">
	<div id="mail-dialog">
		<h1>Email Art of Problem Solving</h1>
		<p>
			<input data-hj-suppress="" data-hj-masked="" type="text" id="email" name="email" placeholder="Your email address">
			<input data-hj-suppress="" data-hj-masked="" type="text" id="subject" name="subject" placeholder="Subject of message">
			<textarea data-hj-suppress="" data-hj-masked="" id="message" name="message" placeholder="Enter your message"></textarea>
			<div style="padding:5px 30px">
				<input type="checkbox" id="email-copy" name="email_copy">
				<label for="email-copy" id="email-copy-label">Send a copy to my email address.</label>
			</div>
			<div style="padding:5px 30px 20px">
				<input id="footer-submit-btn" type="submit" class="btn btn-primary" value="Send">
				<input id="footer-cancel-btn" type="submit" class="btn btn-default" value="Cancel">
			</div>
		</p>
		<p id="email-error"></p>
	</div>
</script>


<script id="footer-tpl-email-confirm" type="text/x-handlebars-template">
	<div id="mail-dialog-confirm">
		<h2>Email Sent</h2>
		<p>Thank you for your email. We will respond to it soon.</p>
	</div>
</script>


<script>
	// Try to prevent sending email multiple times
	var last_email = '';

	$( function() {
		$( ".aops-contact" ).on( "click", displayFooterEmailDialog );

		$( "body" ).on( "click", "#footer-submit-btn", submitFooterEmail );
		$( "body" ).on( "click", "#footer-cancel-btn",  cancelFooterEmail );
	} );

	function displayFooterEmailDialog() {
		AoPS.Ui.Modal.show( {
			body : document.getElementById( "footer-tpl-email-dialog" ).innerHTML,
			max_width : '600px',
			max_height : '100%',
			scrollable : true
		} );
	}


	/**
	 * Submit email
	 *
	 * Note: Copy does not work in non-production mode because Mailer::quick() is
	 * used which does not do force send.
	 */
	function submitFooterEmail() {
		var obj = {
			action : "email",
			email : $( "#email" ).val(),
			subject : $( "#subject" ).val(),
			message : $( "#message" ).val(),
			copy : $( "#email-copy" ).is( ":checked" )
		};

		if ( obj.email === last_email ) {
			return;
		}
		last_email = obj.email;

		// If this still happens multiple times, we have
		// something wrong with the internal ajax call.
		AoPS.Ui.Modal.closeAllModals();
		$.post( "/m/contact-us/ajax.php", obj, function( data ) {
			if ( data.error_code ) {
				$( "#email-error" ).text( data.error_msg ? data.error_msg : data.error_code ).show();
			} else {
				AoPS.Ui.Modal.show( {
					body : document.getElementById( "footer-tpl-email-confirm" ).innerHTML,
					max_width : '600px',
					max_height : '100%',
					scrollable : true
				} );
			}
		}, "json" );
	}
	function cancelFooterEmail() {
		AoPS.Ui.Modal.closeAllModals();
	}
</script>


